# Backend (.env in /backend)
DATABASE_URL=../data/svcii.db
ANTHROPIC_API_KEY=              # Required only for PDF claim extraction (pipeline/07_parse_esg_reports.py)
CORS_ORIGINS=https://svcii.vercel.app,http://localhost:3000

# NASA Earthdata login (required for VIIRS download in pipeline/05_fetch_viirs.py)
EARTHDATA_USER=
EARTHDATA_PASS=

# Frontend (.env.local in /frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
# For production: NEXT_PUBLIC_API_URL=https://svcii-api.onrender.com
